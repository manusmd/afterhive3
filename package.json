{
  "name": "afterhive",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:infra": "docker compose up postgres redis meilisearch -d",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @afterhive/db generate",
    "db:migrate": "pnpm --filter @afterhive/db migrate",
    "db:seed": "tsx scripts/seed-demo.ts",
    "billing:recurring": "tsx scripts/run-recurring-invoices.ts",
    "billing:per-session": "tsx scripts/run-per-session-billing.ts",
    "billing:dunning": "tsx scripts/run-dunning-advance.ts",
    "billing:enrollment": "tsx scripts/run-enrollment-invoices.ts",
    "billing:custom": "tsx scripts/run-custom-invoices.ts",
    "db:studio": "pnpm --filter @afterhive/db studio"
  },
  "devDependencies": {
    "@afterhive/api": "workspace:*",
    "@afterhive/db": "workspace:*",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  }
}
